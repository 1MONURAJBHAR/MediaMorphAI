// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {    //we removed this: output = "../generated/prisma" and hence all related files are generated in "node_modules"
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String?
  publicId        String   @unique
  originalSize    Int
  compressedSize  Int
  duration        Float
  createdAt       DateTime @default(now())

  @@index([userId])
}
